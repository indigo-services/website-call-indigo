# Easypanel Environment Variables for Strapi
# Copy these to your Easypanel service configuration

HOST=0.0.0.0
PORT=1337
NODE_ENV=production

# Database Configuration
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Security Keys - REQUIRED for Strapi to start
APP_KEYS=changeMeToRandomString1,changeMeToRandomString2,changeMeToRandomString3,changeMeToRandomString
API_TOKEN_SALT=changeMeToRandomString
ADMIN_JWT_SECRET=changeMeToRandomString
TRANSFER_TOKEN_SALT=changeMeToRandomString
JWT_SECRET=changeMeToRandomString
ADMIN_AUTH_SECRET=changeMeToRandomString
ADMIN_PATH=/admin

# Client Configuration
CLIENT_URL=https://your-vercel-domain.example.com
PREVIEW_SECRET=changeMeToRandomString

# CORS Configuration
URL=https://your-strapi-domain.example.com
PUBLIC_URL=https://your-strapi-domain.example.com
