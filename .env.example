# Root portable environment template
# Copy the values you need into .env or .env.easypanel.local.

# Easypanel control plane
EASYPANEL_API=
EASYPANEL_API_URL=https://vps10.riolabs.ai/api
EASYPANEL_PROJECT_NAME=riostack
EASYPANEL_SERVICE_NAME=indigo-studio
EASYPANEL_SERVICE_TYPE=compose
EASYPANEL_STRAPI_CONTAINER=indigo-strapi
EASYPANEL_GITHUB_OWNER=indigo-buildops
EASYPANEL_GITHUB_REPO=indigo-studio
EASYPANEL_GITHUB_REF=main
EASYPANEL_STRAPI_PATH=/strapi
EASYPANEL_STRAPI_DOMAIN=
EASYPANEL_ADMIN_PATH=/admin
EASYPANEL_STRAPI_HEALTH_PATH=/

# Shared runtime URLs
# WEBSITE_URL should point at the Vercel-hosted frontend.
WEBSITE_URL=https://indigo-website-cms.vercel.app
NEXT_PUBLIC_API_URL=https://indigo-website-cms.vercel.app
STRAPI_URL=https://riostack-indigo-studio.ck87nu.easypanel.host

ENVIRONMENT=production

# Existing integrations
# On Windows, user-level env vars are honored by the loader, so these can stay empty here if already set globally.
=https://api.z.ai/api/paas/v4
