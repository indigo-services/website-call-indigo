{
  "name": "indigo-studio-platform",
  "version": "0.0.1",
  "description": "INDIGO Control Panel Dashboard",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "next": "yarn dev --prefix ../next/",
    "setup": "yarn && yarn setup:next && yarn setup:strapi && yarn setup:env && yarn doctor",
    "strapi": "yarn dev --prefix ../strapi/",
    "ghp": "ghp",
    "ghp:plan": "ghp plan",
    "ghp:work": "ghp work",
    "ghp:fields": "ghp fields",
    "ghp:start": "ghp start",
    "ghp:pr": "ghp pr",
    "ghp:status": "ghp status",
    "ghp:config:show": "ghp config --show -w",
    "setup:next": "cd next && yarn && node --loader ts-node/esm ../scripts/copy-env.mts ../next",
    "setup:strapi": "cd strapi && yarn && node --loader ts-node/esm ../scripts/copy-env.mts  ../strapi",
    "setup:env": "node --loader ts-node/esm ./scripts/bootstrap-env.mts",
    "setup:ci": "yarn && yarn setup:next && yarn setup:strapi && yarn setup:env --non-interactive",
    "doctor": "node --loader ts-node/esm ./scripts/doctor.mts",
    "doctor:strict": "node --loader ts-node/esm ./scripts/doctor.mts --strict",
    "check:strapi": "yarn --cwd strapi build",
    "dev": "yarn concurrently \"cd strapi && yarn develop\" \"npx wait-on http://localhost:1337 && cd next && yarn dev\"",
    "seed": "cd strapi && yarn strapi import -f ./data/export_20250116105447.tar.gz --force",
    "export": "cd strapi && yarn strapi export --no-encrypt -f ./data/export_20250116105447",
    "repo:upstream": "git fetch upstream && git merge upstream/main",
    "check:format": "prettier . --check --cache",
    "fix:format": "prettier . --write --cache",
    "fix": "yarn fix:format",
    "lint-staged": "lint-staged",
    "validate:prod": "node --loader ts-node/esm ./scripts/validate-prod.mts",
    "health:check": "node --loader ts-node/esm ./scripts/health-check.mts",
    "toolset:init": "node --loader ts-node/esm ./scripts/toolset-init.mts",
    "test:toolset": "node --loader ts-node/esm ./scripts/test/toolset-config.test.mts",
    "ci:status": "node --loader ts-node/esm ./scripts/ci-status.mts",
    "validate:strapi:build": "node scripts/validate-strapi-build.mjs",
    "verify:endpoints:local": "node scripts/verify-endpoints.mjs http://localhost:3000",
    "verify:endpoints:prod": "node scripts/verify-endpoints.mjs",
    "report:visual": "node scripts/generate-visual-report.mjs http://localhost:3000",
    "easypanel": "echo '############  EasyPanel Deploy  ############'",
    "ep:init": "node --loader ts-node/esm ./scripts/easypanel-init.mts",
    "ep:doctor": "node --loader ts-node/esm ./scripts/easypanel-ops.mts doctor",
    "ep:status": "node --loader ts-node/esm ./scripts/easypanel-ops.mts status",
    "ep:health": "node --loader ts-node/esm ./scripts/easypanel-ops.mts health",
    "ep:cron": "node --loader ts-node/esm ./scripts/easypanel-ops.mts cron",
    "ep:recommend": "node --loader ts-node/esm ./scripts/easypanel-ops.mts recommend",
    "ep:bootstrap": "node --loader ts-node/esm ./scripts/easypanel-ops.mts bootstrap",
    "ep:bootstrap-deploy": "node --loader ts-node/esm ./scripts/easypanel-ops.mts bootstrap-deploy",
    "ep:deploy": "node --loader ts-node/esm ./scripts/easypanel-ops.mts deploy",
    "easypanel:init": "yarn ep:init",
    "easypanel:doctor": "yarn ep:doctor",
    "easypanel:status": "yarn ep:status",
    "easypanel:health": "yarn ep:health",
    "easypanel:cron": "yarn ep:cron",
    "easypanel:recommend": "yarn ep:recommend",
    "easypanel:bootstrap": "yarn ep:bootstrap",
    "easypanel:bootstrap-deploy": "yarn ep:bootstrap-deploy",
    "easypanel:deploy": "yarn ep:deploy",
    "versel": "echo '############  VERCEL DEPLOY  ############'",
    "deploy:prod": "yarn validate:prod && vercel --prod",
    "deploy:preview": "vercel",
    "deploy:ep": "node --loader ts-node/esm ./scripts/deploy-easypanel.mts",
    "deploy:ep:api": "node --loader ts-node/esm ./scripts/deploy-easypanel-api.mts",
    "deploy:easypanel": "yarn deploy:ep",
    "deploy:easypanel:api": "yarn deploy:ep:api",
    "deploy:next:github": "powershell -ExecutionPolicy Bypass -File ./scripts/push-next-website-call-indigo.ps1"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.5.2",
    "concurrently": "^8.2.2",
    "typescript": "^5.0.0",
    "wait-on": "^8.0.1"
  },
  "devDependencies": {
    "@bretwardjames/ghp-cli": "0.18.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.5.3",
    "yalc": "^1.0.0-pre.53",
    "ts-node": "^10.9.2",
    "uuid": "^13.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,yml,yaml}": [
      "yarn fix:format"
    ],
    "next/**/*.{js,jsx,ts,tsx}": [
      "cd next && yarn lint --fix"
    ]
  },
  "packageManager": "yarn@4.13.0"
}
