# Production Environment Configuration
# Copy this to .env.production and update values for your production environment

# Application URLs
WEBSITE_URL=https://your-domain.com
NEXT_PUBLIC_API_URL=https://api.your-domain.com

# Environment
ENVIRONMENT=production

# Strapi Configuration
DATABASE_URL=postgresql://user:password@your-db-host:5432/strapi_prod
JWT_SECRET=your-jwt-secret-key
ADMIN_JWT_SECRET=your-admin-jwt-secret

# NextAuth (if using authentication)
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=https://your-domain.com

# Vercel Configuration
VERCEL_URL=your-domain.com

# Image Optimization
IMAGE_HOSTNAME=cdn.your-domain.com

# Third-party Services
# SENDGRID_API_KEY=
# STRIPE_SECRET_KEY=
# ANALYTICS_ID=

# Features
NEXT_TELEMETRY_DISABLED=1
